# Script de lanzamiento para Chromium QuantumDev con aceleración total
#!/bin/bash
# Ubicación: /usr/local/bin/quantum-browser

# Crear grupo de control dinámico
CGROUP_NAME="quantum_browsing"
sudo cgcreate -g cpu,memory,io:$CGROUP_NAME

# Optimizar para Vulkan y VA-API
export ENABLE_VULKAN=1
export DISPLAY=:0
export LIBVA_DRIVER_NAME=iHD # O radeonsi dependiendo del hardware de Mexicali

cgexec -g cpu,memory,io:$CGROUP_NAME \
    chromium --enable-features=Vulkan,VulkanFromANGLE,DefaultANGLEVulkan,VaapiVideoDecoder \
             --ignore-gpu-blocklist \
             --enable-zero-copy \
             --force-color-profile=bt2020 \
             --use-gl=angle --angle=vulkan
