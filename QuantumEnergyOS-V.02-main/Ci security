# ──────────────────────────────────────────────────────────────
#  QuantumEnergyOS — CI: Security Scan
#  Corre en cada PR hacia main y semanalmente.
#  Incluye: bandit, semgrep, trivy, pip-audit, safety, SBOM.
# ──────────────────────────────────────────────────────────────

name: 🔐 Security Scan

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  schedule:
    - cron: "0 6 * * 1"   # Lunes 06:00 UTC (00:00 Mexicali)

permissions:
  contents: read
  security-events: write    # Para subir resultados a GitHub Security tab

jobs:
  # ── 1. Análisis estático Python ─────────────────────────────
  bandit:
    name: 🔍 Bandit (SAST Python)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Instalar bandit
        run: pip install bandit[toml]

      - name: Correr bandit
        run: |
          bandit -r . \
            --exclude ./notebooks,./tests,./.github \
            --format sarif \
            --output bandit-results.sarif \
            --severity-level medium \
            || true

      - name: Upload SARIF a GitHub Security
        uses: github/codeql-action/upload-sarif@v3
        with:
          sarif_file: bandit-results.sarif
          category: bandit

  # ── 2. Semgrep (reglas de seguridad cuántica + general) ─────
  semgrep:
    name: 🔍 Semgrep (SAST avanzado)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Correr Semgrep
        uses: semgrep/semgrep-action@v1
        with:
          config: >-
            p/python
            p/secrets
            p/jwt
            p/owasp-top-ten
        env:
          SEMGREP_APP_TOKEN: ${{ secrets.SEMGREP_APP_TOKEN }}

  # ── 3. Dependencias Python ───────────────────────────────────
  pip-audit:
    name: 📦 pip-audit + safety
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: pip

      - name: Instalar dependencias de auditoría
        run: pip install pip-audit safety

      - name: pip-audit (CVE en dependencias)
        run: |
          pip install -r requirements.txt
          pip-audit --format json --output pip-audit-results.json || true
          pip-audit --format markdown || true

      - name: safety check
        run: safety check --full-report || true

      - name: Upload resultados
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: pip-audit-results
          path: pip-audit-results.json
          retention-days: 30

  # ── 4. Escaneo de imagen Docker ──────────────────────────────
  trivy:
    name: 🐳 Trivy (vulnerabilidades Docker)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build imagen Docker
        run: docker build -t quantumenergyos:ci .

      - name: Trivy — vulnerabilidades en imagen
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: quantumenergyos:ci
          format: sarif
          output: trivy-image.sarif
          severity: CRITICAL,HIGH
          exit-code: "1"        # Falla el CI si hay CVEs críticos
        continue-on-error: true

      - name: Trivy — secrets en filesystem
        uses: aquasecurity/trivy-action@master
        with:
          scan-type: fs
          scan-ref: .
          scanners: secret
          format: table

      - name: Upload SARIF Trivy
        uses: github/codeql-action/upload-sarif@v3
        with:
          sarif_file: trivy-image.sarif
          category: trivy

  # ── 5. Generar SBOM (CycloneDX) ─────────────────────────────
  sbom:
    name: 📋 Generar SBOM (CycloneDX)
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main'
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python + instalar dependencias
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: pip install -r requirements.txt cyclonedx-bom

      - name: Generar SBOM
        run: |
          cyclonedx-py environment \
            --of JSON \
            -o sbom-quantumenergyos.json

      - name: Upload SBOM
        uses: actions/upload-artifact@v4
        with:
          name: sbom-cyclonedx
          path: sbom-quantumenergyos.json
          retention-days: 90

  # ── 6. Verificar secrets en git history ─────────────────────
  gitleaks:
    name: 🔑 Gitleaks (secrets en git)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0    # Historia completa

      - uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
