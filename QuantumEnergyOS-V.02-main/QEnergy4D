body { font-family: 'Segoe UI', sans-serif; background: #0a0a1a; color: #e0e0ff; margin: 0; padding: 2rem; }
h1, h2 { color: #00ffff; text-shadow: 0 0 10px #00ffff; }
.interactive { position: relative; width: 600px; margin: auto; }
img { width: 100%; filter: brightness(1.2); transition: transform 1s; }
.overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.tooltip { opacity: 0; transition: opacity 0.5s; position: absolute; background: rgba(0,255,255,0.3); padding: 10px; border-radius: 5px; }
button { padding: 10px 20px; background: #00ffff; border: none; color: black; cursor: pointer; margin-top: 1rem; }
button:hover { background: #00cccc; }


function rotateCristal() {
    const cristal = document.getElementById('cristal');
    cristal.style.transform = cristal.style.transform === 'rotateY(180deg)' ? 'rotateY(0deg)' : 'rotateY(180deg)';
}

document.querySelectorAll('.tooltip').forEach(tooltip => {
    tooltip.addEventListener('mouseenter', () => {
        tooltip.style.opacity = '1';
    });
    tooltip.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
    });
});

