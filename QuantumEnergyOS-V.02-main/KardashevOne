import numpy as np
import matplotlib.pyplot as plt
from datetime import datetime

# Constantes de la escala de Kardashev (aproximaciones estándar)
K0_ENERGY_W = 1e12          # Consumo energético humano actual ~10¹²–10¹³ W (2020s)
K1_ENERGY_W = 1.74e17       # Potencia incidente solar en la Tierra (~1.74 × 10¹⁷ W)
K_TYPE1_TARGET = 1.0

# Datos históricos aproximados (consumo energético global en EJ/año → convertido a potencia media)
# 1 EJ = 10¹⁸ J → potencia = EJ / (365.25 * 86400) W
historical_years = np.array([1960, 1980, 2000, 2020, 2025])
historical_power_W = np.array([5e12, 8e12, 1.2e13, 1.8e13, 2.2e13])  # Ajustado a ~2025

def kardashev_index(power_w):
    """Calcula el índice K de Sagan: K = (log10(P) - 6) / 10"""
    return (np.log10(power_w) - 6) / 10

# Índice K actual (aprox. 2025–2026)
current_power = historical_power_W[-1]
current_k = kardashev_index(current_power)
print(f"Índice Kardashev actual (aprox. {datetime.now().year}): {current_k:.4f}")
print(f"Potencia controlada: {current_power:.2e} W")

# Proyección exponencial simple: crecimiento anual compuesto
def project_to_type1(
    initial_power,
    target_power,
    growth_rate_annual=0.02,      # Crecimiento histórico ~1.5–2.5%; asumimos 2%
    quantum_acceleration_factor=1.5,  # Aceleración por fusión/cuántico (hipotético)
    years_step=1
):
    years = 0
    power = initial_power
    history = [(years, power, kardashev_index(power))]
    
    while power < target_power:
        # Aplicar crecimiento base + acelerador (e.g., fusión viable post-2040)
        effective_growth = growth_rate_annual
        if years > 15:  # Suponiendo avances cuánticos/fusión ~2040+
            effective_growth *= quantum_acceleration_factor
        
        power *= (1 + effective_growth)
        years += years_step
        history.append((years, power, kardashev_index(power)))
        
        if years > 1000:  # Evitar bucles infinitos
            break
    
    return history

# Escenario base (sin aceleración drástica)
print("\nProyección base (crecimiento 2% anual):")
base_history = project_to_type1(current_power, K1_ENERGY_W, growth_rate_annual=0.02)

# Escenario optimista: fusión + cómputo cuántico acelera 50% extra post-2040
print("\nProyección optimista (crecimiento 2% + acelerador cuántico 1.5x post-2040):")
optim_history = project_to_type1(current_power, K1_ENERGY_W, growth_rate_annual=0.02, quantum_acceleration_factor=1.5)

# Visualización
def plot_projection(hist, title):
    years, powers, ks = zip(*hist)
    actual_years = [datetime.now().year + y for y in years]
    
    fig, ax1 = plt.subplots(figsize=(10, 6))
    
    ax1.plot(actual_years, powers, 'b-', label='Potencia (W)')
    ax1.set_yscale('log')
    ax1.set_xlabel('Año')
    ax1.set_ylabel('Potencia controlada (W)', color='b')
    ax1.tick_params(axis='y', labelcolor='b')
    
    ax2 = ax1.twinx()
    ax2.plot(actual_years, ks, 'r--', label='Índice K')
    ax2.set_ylabel('Índice Kardashev K', color='r')
    ax2.tick_params(axis='y', labelcolor='r')
    
    plt.title(title)
    plt.grid(True, which="both", ls="--")
    plt.axhline(y=K1_ENERGY_W, color='g', linestyle=':', label='Tipo 1 (~1.74e17 W)')
    plt.legend()
    plt.show()

plot_projection(base_history, "Proyección base hacia Tipo 1")
plot_projection(optim_history, "Proyección optimista (con aceleración cuántica/fusión)")

# Resultado aproximado
years_to_type1_base = base_history[-1][0] if base_history[-1][1] >= K1_ENERGY_W else ">1000"
years_to_type1_optim = optim_history[-1][0] if optim_history[-1][1] >= K1_ENERGY_W else ">1000"

print(f"\nAños estimados para alcanzar Tipo 1 (escenario base): {years_to_type1_base}")
print(f"Años estimados con aceleración cuántica/fusión: {years_to_type1_optim}")

