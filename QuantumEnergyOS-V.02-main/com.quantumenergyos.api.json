{
  "app-id": "com.quantumenergyos.api",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.node20"
  ],
  "command": "python server.py",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--filesystem=home:ro",
    "--filesystem=xdg-config:rw",
    "--filesystem=xdg-data:rw",
    "--device=dri",
    "--env=PYTHONUNBUFFERED=1",
    "--env=QEOS_ENV=production",
    "--env=QEOS_VERSION=0.2.0-immutable",
    "--env=QEOS_MISSION=Nunca más apagones en Mexicali",
    "--env=QEOS_LOCATION=Mexicali, Baja California, México",
    "--env=PORT=8000"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node20/bin"
  },
  "modules": [
    {
      "name": "quantumenergyos-api",
      "buildsystem": "simple",
      "build-commands": [
        "pip install --no-cache-dir -r requirements.txt",
        "install -Dm755 server.py /app/bin/server.py",
        "install -Dm644 core.py /app/lib/core.py",
        "install -Dm644 config.toml /app/etc/config.toml"
      ],
      "sources": [
        {
          "type": "file",
          "path": "requirements.txt"
        },
        {
          "type": "file",
          "path": "server.py"
        },
        {
          "type": "file",
          "path": "core.py"
        },
        {
          "type": "file",
          "path": "config.toml"
        }
      ]
    }
  ]
}