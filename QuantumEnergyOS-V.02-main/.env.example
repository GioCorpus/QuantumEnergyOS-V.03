# QuantumEnergyOS V.02 — Variables de entorno
# Copiar a .env y ajustar según infraestructura

# ── API ────────────────────────────────────────────────────────────────────
PORT=8000
QEOS_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── IBM Quantum ────────────────────────────────────────────────────────────
# IBM_QUANTUM_TOKEN=tu_token_aqui

# ── Azure Quantum ──────────────────────────────────────────────────────────
# AZURE_QUANTUM_TOKEN=tu_token_aqui

# ── Qiskit Configuration ───────────────────────────────────────────────────
QISKIT_AER_BACKEND=aer_simulator
QISKIT_NOISE_MODEL=false

# ── OpenWeatherMap (Climate Orchestrator) ─────────────────────────────────
OPENWEATHER_API_KEY=tu_api_key_aqui
QEOS_LOCATION=Mexicali, Baja California, MX

# ── Climate Orchestrator ajustes ───────────────────────────────────────────
# Modo simulación (true=no ejecuta acciones reales)
CLIMATE_DRY_RUN=true

# Monitor automático en background (cada 5 min por defecto)
CLIMATE_MONITOR_ENABLED=false
MONITOR_INTERVAL_SEC=300

# ── Rust Bridge (opcional) ─────────────────────────────────────────────────
# Si compilaste photonic-bridge para acciones nativas de bajo nivel
USE_RUST_BRIDGE=false
PHOTONIC_BRIDGE_PATH=./photonic-bridge/target/release/photonic-bridge

# ── Detector de apagones ───────────────────────────────────────────────────
# URL donde corre QuantumEnergyOS (detector_apagones.py)
QEOS_API_URL=http://localhost:8000/api/alert
