from fastapi import FastAPI
from pydantic import BaseModel
from datetime import datetime
import json

app = FastAPI(title="QuantumEnergyOS API")

class PowerAlert(BaseModel):
    timestamp: str
    type: str = "power_outage"
    location: str = "Mexicali"
    source: str
    severity: str = "high"

# Base de datos temporal en memoria (puedes cambiarla después)
alertas = []

@app.post("/api/alert")
async def recibir_alerta(alerta: PowerAlert):
    alerta_dict = alerta.dict()
    alerta_dict = datetime.now().isoformat()
    
    alertas.append(alerta_dict)
    
    print(f"🚨 Alerta recibida: {alerta_dict}")
    
    return {
        "status": "success",
        "message": "Alerta procesada por QuantumEnergyOS",
        "alert_id": len(alertas),
        "quantum_status": "QAOA optimization queued"  # Mensaje para que se sienta tu vibe cuántica
    }

@app.get("/api/alerts")
async def obtener_alertas():
    return {"alertas": alertas[-20:]}  # últimas 20 alertas
