-- DIVISION DE IDENTIFICACION
SELECT 'PROGRAMA: MONITOREO-ENERGETICO' AS PROGRAM_NAME;

-- DIVISION DE DATOS
CREATE TABLE IF NOT EXISTS MONITOREO_ENERGETICO (
    ID_MONITOREO         SERIAL PRIMARY KEY,
    FECHA_MONITOREO      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CARGA_TOTAL_MW       DECIMAL(10,2),
    CAPACIDAD_TOTAL_MW   DECIMAL(10,2),
    PORCENTAJE_UTILIZADO DECIMAL(5,2),
    NODOS_ACTIVOS        INTEGER,
    ALERTAS_ACTIVAS      INTEGER,
    INDICE_SOLAR_KP      DECIMAL(3,1),
    ESTADO_GENERAL       VARCHAR(20),
    OBSERVACIONES        TEXT
);

-- DIVISION DE PROCEDIMIENTO
INSERT INTO MONITOREO_ENERGETICO (
    CARGA_TOTAL_MW,
    CAPACIDAD_TOTAL_MW,
    PORCENTAJE_UTILIZADO,
    NODOS_ACTIVOS,
    ALERTAS_ACTIVAS,
    INDICE_SOLAR_KP,
    ESTADO_GENERAL,
    OBSERVACIONES
)
SELECT 
    SUM(n.CARGA_ACTUAL_MW) AS CARGA_TOTAL_MW,
    SUM(n.CAPACIDAD_MW) AS CAPACIDAD_TOTAL_MW,
    ROUND((SUM(n.CARGA_ACTUAL_MW) / NULLIF(SUM(n.CAPACIDAD_MW), 0)) * 100, 2) AS PORCENTAJE_UTILIZADO,
    COUNT(*) AS NODOS_ACTIVOS,
    COUNT(CASE WHEN n.CARGA_ACTUAL_MW > (n.CAPACIDAD_MW * 0.90) THEN 1 END) AS ALERTAS_ACTIVAS,
    ROUND(RANDOM() * 8, 1) AS INDICE_SOLAR_KP,  -- Valor simulado
    CASE 
        WHEN SUM(n.CARGA_ACTUAL_MW) / NULLIF(SUM(n.CAPACIDAD_MW), 0) > 0.90 THEN 'CRITICO'
        WHEN SUM(n.CARGA_ACTUAL_MW) / NULLIF(SUM(n.CAPACIDAD_MW), 0) > 0.80 THEN 'PRECAUCIÓN'
        ELSE 'ESTABLE'
    END AS ESTADO_GENERAL,
    'Monitoreo realizado desde Mexicali, BC' AS OBSERVACIONES
FROM NODOS_RED n;

-- DISPLAY FINAL DEL MONITOREO
SELECT 
    '=== REPORTE DE MONITOREO ENERGETICO ===' AS TITULO,
    TO_CHAR(FECHA_MONITOREO, 'YYYY-MM-DD HH24:MI:SS') AS FECHA,
    CARGA_TOTAL_MW AS "CARGA TOTAL (MW)",
    PORCENTAJE_UTILIZADO || '%' AS "UTILIZACIÓN",
    NODOS_ACTIVOS AS "NODOS ACTIVOS",
    ALERTAS_ACTIVAS AS "ALERTAS",
    INDICE_SOLAR_KP AS "ÍNDICE SOLAR (Kp)",
    ESTADO_GENERAL AS ESTADO,
    OBSERVACIONES
FROM MONITOREO_ENERGETICO 
ORDER BY ID_MONITOREO DESC 
LIMIT 1;
