-- DIVISION DE IDENTIFICACION
SELECT 'PROGRAMA: CREACION-DE-TABLAS' AS PROGRAM_NAME;

-- DIVISION DE DATOS (DATA DIVISION)
-- Creamos las tablas principales del sistema energético

-- Tabla principal de nodos de la red (como un FD en COBOL)
CREATE TABLE IF NOT EXISTS NODOS_RED (
    ID_NODO              SERIAL PRIMARY KEY,
    NOMBRE_NODO          VARCHAR(50) NOT NULL,
    CIUDAD               VARCHAR(30) DEFAULT 'Mexicali',
    CAPACIDAD_MW         DECIMAL(8,2) NOT NULL,
    CARGA_ACTUAL_MW      DECIMAL(8,2) DEFAULT 0.00,
    ESTADO               VARCHAR(20) DEFAULT 'NORMAL',
    FECHA_CREACION       TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla de mediciones en tiempo real (Working Storage)
CREATE TABLE IF NOT EXISTS MEDICIONES_TIEMPO_REAL (
    ID_MEDICION          SERIAL PRIMARY KEY,
    ID_NODO              INTEGER REFERENCES NODOS_RED(ID_NODO),
    CARGA_MW             DECIMAL(8,2) NOT NULL,
    VOLTAJE_KV           DECIMAL(6,2),
    FRECUENCIA_HZ        DECIMAL(5,3),
    TEMPERATURA_C        DECIMAL(5,2),
    FECHA_MEDICION       TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- DIVISION DE PROCEDIMIENTO (PROCEDURE DIVISION)
-- Insertamos los primeros nodos de la red (como un PERFORM)

INSERT INTO NODOS_RED (NOMBRE_NODO, CAPACIDAD_MW, CIUDAD)
VALUES 
    ('Mexicali Centro',     120.00, 'Mexicali'),
    ('Mexicali Industrial',  85.00, 'Mexicali'),
    ('Tijuana Norte',       150.00, 'Tijuana')
ON CONFLICT DO NOTHING;

-- Mostramos el resultado final
SELECT 
    'SE CREARON LAS TABLAS CORRECTAMENTE' AS ESTADO,
    COUNT(*) AS TOTAL_NODOS
FROM NODOS_RED;
