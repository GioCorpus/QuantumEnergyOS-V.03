service = QiskitRuntimeService(channel="ibm_quantum", token="TU_TOKEN")

from qiskit import QuantumCircuit
from qiskit_ibm_runtime import QiskitRuntimeService, SamplerV2 as Sampler

# Carga el servicio
service = QiskitRuntimeService()

# Backend específico: ibm_kingston (Heron R2, 156 qubits)
backend = service.backend("ibm_kingston")

# Circuito básico de prueba (ej. GHZ de 3 qubits, pero puedes meter tu QAOA)
qc = QuantumCircuit(3)
qc.h(0)
qc.cx(0, 1)
qc.cx(1, 2)
qc.measure_all()

# Sampler v2 - ideal para counts
sampler = Sampler(backend=backend)

# Corre el job (shots=1024, ajusta según tu quota)
job = sampler.run( , shots=1024)

print(f"Job ID: {job.job_id()}")  # Copia esto para trackear
result = job.result()
counts = result[0].data.meas.get_counts()
print("Resultados:", counts)
