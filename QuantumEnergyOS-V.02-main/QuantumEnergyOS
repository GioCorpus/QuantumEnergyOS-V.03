<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quantum Energy OS - MIT 1998 Edition</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');
    
    body {
      margin: 0;
      padding: 0;
      background: #008080; /* teal clásico de Windows 95 */
      color: #00ff00; /* verde fósforo CRT */
      font-family: 'VT323', monospace;
      font-size: 20px;
      image-rendering: pixelated;
      overflow: hidden;
      cursor: url('https://cur.cursors-4u.net/nature/nat-10/nat957.cur'), auto;
    }
    
    /* Scanlines retro */
    body::before {
      content: "";
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: repeating-linear-gradient(
        transparent 0px,
        transparent 2px,
        rgba(0,0,0,0.4) 2px,
        rgba(0,0,0,0.4) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }
    
    .container {
      max-width: 800px;
      margin: 40px auto;
      border: 4px solid #c0c0c0;
      background: #000080;
      padding: 20px;
      box-shadow: 0 0 0 8px #000;
      position: relative;
    }
    
    h1 {
      text-align: center;
      color: #ffff00;
      text-shadow: 2px 2px #ff00ff;
      font-size: 48px;
      margin: 0;
      letter-spacing: 4px;
    }
    
    .blink {
      animation: blink 1s infinite;
    }
    @keyframes blink {
      50% { opacity: 0; }
    }
    
    .cactus { 
      position: absolute;
      bottom: 10px;
      left: 20px;
      width: 120px;
      image-rendering: pixelated;
      filter: brightness(1.5) drop-shadow(0 0 10px lime);
    }
    
    .glow {
      animation: glow 2s infinite alternate;
    }
    @keyframes glow {
      from { text-shadow: 0 0 10px #00ffff; }
      to   { text-shadow: 0 0 30px #00ffff, 0 0 50px #00ffff; }
    }
    
    .construction {
      position: absolute;
      top: 10px; right: 10px;
      font-size: 24px;
      color: #ff0000;
      background: yellow;
      padding: 5px 10px;
      border: 3px double red;
      animation: blink 0.8s infinite;
    }
    
    .button {
      display: block;
      margin: 30px auto;
      padding: 15px 40px;
      background: #c0c0c0;
      border: 4px outset #ffffff;
      font-family: 'VT323', monospace;
      font-size: 24px;
      color: #000;
      cursor: pointer;
      box-shadow: 0 0 20px #00ffff;
    }
    .button:active {
      border-style: inset;
      transform: translate(2px, 2px);
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="construction">UNDER CONSTRUCTION</div>
    
    <h1 class="glow">QUANTUM ENERGY OS</h1>
    <p class="subtitle">Desde Mexicali, Baja California – 1998 Edition</p>
    
    <img src="https://i.imgur.com/9zY8J4L.png" class="cactus left" alt="Saguaro pixelado">
    <img src="https://i.imgur.com/9zY8J4L.png" class="cactus right" alt="Saguaro pixelado">
    
    <div class="scene">
      <div class="cube">
        <div class="face front"  data-desc="Qubits Majorana – ¡No se descoherencian!">Capa Física</div>
        <div class="face back"   data-desc="Nudos topológicos – Como un lazo en el desierto">Capa Topológica</div>
        <div class="face right"  data-desc="Cuarzo 4D – Memoria del futuro, brillo del pasado">Capa Almacenamiento</div>
        <div class="face left"   data-desc="Fusión + redes – Energía infinita, cero facturas">Capa Energía</div>
        <div class="face top"    data-desc="Q# – Código que no necesita café">Interfaz Mortal</div>
        <div class="face bottom" data-desc="Kardashev 1 – El Sol es nuestro panel solar">Visión</div>
      </div>
    </div>
    
    <button onclick="simulateEnergy()">¡Optimizar red energética!</button>
  </div>

  <script>
    function simulateEnergy() {
      const messages = [
        "¡Red optimizada! +1.2 GW desde Mexicali",
        "Fusión encendida – el desierto brilla",
        "Cactus cuánticos detectados: 100% uptime",
        "K = 0.999... ¡Ya casi, compa!"
      ];
      alert(messages );
    }
  </script>
</body>
</html>
