"""
security/threat_detection.py
─────────────────────────────
Detección de amenazas y logging de auditoría para QuantumEnergyOS.

Detecta:
- Solicitudes con qubits extremos (posible DoS)
- Patrones de fuerza bruta (muchos tokens inválidos)
- Circuit hashes repetidos (replay de circuitos)
- Anomalías estadísticas en parámetros
"""

from __future__ import annotations

import hashlib
import json
import logging
import time
from collections import defaultdict, deque
from dataclasses import dataclass, field
from datetime import datetime, timezone
from enum import Enum
from typing import Any

# ── Logger estructurado ───────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format='{"time":"%(asctime)s","level":"%(levelname)s","msg":%(message)s}',
    datefmt="%Y-%m-%dT%H:%M:%SZ",
)
logger = logging.getLogger("qeos.security")


# ── Niveles de amenaza ────────────────────────────────────────
class ThreatLevel(str, Enum):
    INFO     = "INFO"
    LOW      = "LOW"
    MEDIUM   = "MEDIUM"
    HIGH     = "HIGH"
    CRITICAL = "CRITICAL"


@dataclass
class ThreatEvent:
    """Evento de amenaza detectado."""
    threat_type:  str
    level:        ThreatLevel
    identifier:   str                        # IP o sub JWT (hashed)
    description:  str
    timestamp:    datetime = field(
        default_factory=lambda: datetime.now(timezone.utc)
    )
    metadata:     dict[str, Any] = field(default_factory=dict)

    def to_dict(self) -> dict[str, Any]:
        return {
            "threat_type":  self.threat_type,
            "level":        self.level.value,
            "identifier":   hashlib.sha256(
                self.identifier.encode()
            ).hexdigest()[:16],
            "description":  self.description,
            "timestamp":    self.timestamp.isoformat(),
            "metadata":     self.metadata,
        }


# ── Detectores ────────────────────────────────────────────────
class ThreatDetector:
    """Motor de detección de amenazas para solicitudes de circuitos cuánticos."""

    # Ventana de análisis
    WINDOW_SECONDS     = 300     # 5 minutos
    MAX_FAILED_AUTHS   = 10      # intentos fallidos antes de alerta
    MAX_CIRCUIT_REPLAY = 5       # veces que se puede repetir el mismo hash
    QUBIT_SPIKE_RATIO  = 4.0     # ratio de qubits vs media antes de alerta

    def __init__(self) -> None:
        self._failed_auths:  dict[str, deque] = defaultdict(deque)
        self._circuit_hashes: dict[str, int]  = defaultdict(int)
        self._qubit_history: deque[int]        = deque(maxlen=100)
        self._events:        list[ThreatEvent] = []

    # ── Detección individual ──────────────────────────────────
    def check_auth_failure(self, identifier: str) -> ThreatEvent | None:
        """Detecta intentos repetidos de autenticación fallida."""
        now    = time.monotonic()
        cutoff = now - self.WINDOW_SECONDS
        q = self._failed_auths[identifier]
        q.append(now)
        # Purgar entradas antiguas
        while q and q[0] < cutoff:
            q.popleft()

        if len(q) >= self.MAX_FAILED_AUTHS:
            return ThreatEvent(
                threat_type="BRUTE_FORCE_AUTH",
                level=ThreatLevel.HIGH,
                identifier=identifier,
                description=(
                    f"{len(q)} intentos de autenticación fallidos "
                    f"en {self.WINDOW_SECONDS}s"
                ),
                metadata={"failed_count": len(q)},
            )
        return None

    def check_circuit_replay(
        self, circuit_hash: str, identifier: str
    ) -> ThreatEvent | None:
        """Detecta replay de circuitos idénticos."""
        self._circuit_hashes[circuit_hash] += 1
        count = self._circuit_hashes[circuit_hash]

        if count > self.MAX_CIRCUIT_REPLAY:
            return ThreatEvent(
                threat_type="CIRCUIT_REPLAY",
                level=ThreatLevel.MEDIUM,
                identifier=identifier,
                description=(
                    f"Circuito {circuit_hash[:8]}... ejecutado "
                    f"{count} veces (máx {self.MAX_CIRCUIT_REPLAY})"
                ),
                metadata={"hash": circuit_hash[:16], "count": count},
            )
        return None

    def check_qubit_anomaly(
        self, qubits: int, identifier: str
    ) -> ThreatEvent | None:
        """Detecta solicitudes con número inusualmente alto de qubits."""
        self._qubit_history.append(qubits)
        if len(self._qubit_history) >= 10:
            media = sum(self._qubit_history) / len(self._qubit_history)
            if media > 0 and qubits / media > self.QUBIT_SPIKE_RATIO:
                return ThreatEvent(
                    threat_type="QUBIT_SPIKE",
                    level=ThreatLevel.MEDIUM,
                    identifier=identifier,
                    description=(
                        f"Solicitud de {qubits} qubits vs media "
                        f"{media:.1f} (ratio={qubits/media:.1f}x)"
                    ),
                    metadata={"qubits": qubits, "mean": round(media, 2)},
                )
        return None

    def check_parameter_anomaly(
        self, parameters: dict[str, float], identifier: str
    ) -> ThreatEvent | None:
        """Detecta parámetros en los extremos del rango permitido."""
        suspicious = {
            k: v for k, v in parameters.items()
            if abs(v) > 1e5
        }
        if suspicious:
            return ThreatEvent(
                threat_type="EXTREME_PARAMETERS",
                level=ThreatLevel.LOW,
                identifier=identifier,
                description=f"Parámetros extremos: {list(suspicious.keys())}",
                metadata={"params": {k: round(v, 4) for k, v in suspicious.items()}},
            )
        return None

    # ── Análisis completo ─────────────────────────────────────
    def analyze_request(
        self,
        identifier: str,
        qubits: int,
        circuit_hash: str,
        parameters: dict[str, float],
    ) -> list[ThreatEvent]:
        """
        Analiza una solicitud completa y retorna todos los eventos detectados.
        Registra automáticamente en el logger.
        """
        events: list[ThreatEvent] = []

        checks = [
            self.check_circuit_replay(circuit_hash, identifier),
            self.check_qubit_anomaly(qubits, identifier),
            self.check_parameter_anomaly(parameters, identifier),
        ]

        for event in checks:
            if event is not None:
                events.append(event)
                self._events.append(event)
                self._log_event(event)

        return events

    def record_auth_failure(self, identifier: str) -> None:
        """Registrar fallo de autenticación y detectar brute force."""
        event = self.check_auth_failure(identifier)
        if event:
            self._events.append(event)
            self._log_event(event)

    # ── Logging ───────────────────────────────────────────────
    def _log_event(self, event: ThreatEvent) -> None:
        """Emite el evento al logger con el nivel apropiado."""
        msg = json.dumps(event.to_dict())
        level_map = {
            ThreatLevel.INFO:     logger.info,
            ThreatLevel.LOW:      logger.info,
            ThreatLevel.MEDIUM:   logger.warning,
            ThreatLevel.HIGH:     logger.error,
            ThreatLevel.CRITICAL: logger.critical,
        }
        level_map[event.level](msg)

    def get_recent_events(
        self,
        level: ThreatLevel | None = None,
        limit: int = 50,
    ) -> list[dict[str, Any]]:
        """Retorna los eventos más recientes, opcionalmente filtrados por nivel."""
        events = self._events
        if level:
            events = [e for e in events if e.level == level]
        return [e.to_dict() for e in events[-limit:]]


# ── Singleton global ──────────────────────────────────────────
detector = ThreatDetector()
