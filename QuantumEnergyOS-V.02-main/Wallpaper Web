<h1>Quantum Energy OS</h1>
<p>Desde el desierto de Baja California hacia Kardashev Tipo 1 – Un oasis cuántico en el Sonora</p>

const konamiCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'KeyB', 'KeyA'];
let konamiIndex = 0;

document.addEventListener('keydown', (e) => {
  if (e.key === konamiCode ) {
    konamiIndex++;
    if (konamiIndex === konamiCode.length) {
      konamiIndex = 0;
      const sonic = document.createElement('img');
      sonic.src = 'https://i.imgur.com/8zK9j4L.png'; // Sonic pixelado (cámbialo por el tuyo)
      sonic.style.position = 'absolute';
      sonic.style.bottom = '20%';
      sonic.style.left = '-200px';
      sonic.style.width = '150px';
      sonic.style.transition = 'left 5s linear';
      sonic.style.filter = 'drop-shadow(0 0 15px lime)';
      document.body.appendChild(sonic);
      
      setTimeout(() => {
        sonic.style.left = '120%';
      }, 100);
      
      setTimeout(() => {
        sonic.remove();
        alert('¡Gracias, Linus! Recibo CFE: 0 pesos. El desierto gana.');
      }, 5200);
    }
  } else {
    konamiIndex = 0;
  }
});

