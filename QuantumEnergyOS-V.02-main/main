# ─────────────────────────────────────────────────────────────
#  QuantumEnergyOS — CI: Q# Simulations
#  Corre en cada PR hacia main y en cada push a main.
#  Requisito para merge (branch protection).
# ─────────────────────────────────────────────────────────────

name: 🔬 Q# Simulations

on:
  push:
    branches: [main]
    paths:
      - "src/**/*.qs"
      - "**/*.csproj"
  pull_request:
    branches: [main]
    paths:
      - "src/**/*.qs"
      - "**/*.csproj"

jobs:
  qsharp-simulate:
    name: Compilar y simular Q#
    runs-on: ubuntu-latest

    steps:
      # 1. Checkout del código
      - name: 📥 Checkout
        uses: actions/checkout@v4

      # 2. Instalar .NET SDK (requerido por QDK)
      - name: ⚙️ Setup .NET 8
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: "8.0.x"

      # 3. Instalar Microsoft Quantum Development Kit
      - name: ⚛️ Instalar QDK (Microsoft.Quantum.Sdk)
        run: |
          dotnet tool install -g Microsoft.Quantum.IQSharp
          dotnet iqsharp install --user

      # 4. Restaurar dependencias del proyecto
      - name: 📦 Restaurar dependencias
        run: dotnet restore src/

      # 5. Compilar todos los archivos Q#
      - name: 🏗️ Build Q# project
        run: dotnet build src/ --no-restore --configuration Release

      # 6. Correr simulaciones (BalancearRed, FusionSim, BraidingDebug)
      - name: 🚀 Simular BalancearRed
        run: dotnet run --project src/ -- BalancearRed
        continue-on-error: false

      - name: 🌡️ Simular FusionSim
        run: dotnet run --project src/ -- FusionSim
        continue-on-error: true   # aún en desarrollo

      - name: 🔗 Simular BraidingDebug
        run: dotnet run --project src/ -- BraidingDebug
        continue-on-error: true   # aún en desarrollo

      # 7. Guardar resultados como artifact de Actions
      - name: 💾 Upload simulation logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: simulation-results
          path: |
            src/**/*.log
            src/**/output*.txt
          retention-days: 14

          # ─────────────────────────────────────────────────────────────
#  QuantumEnergyOS — CI: Python + Qiskit Simulations
#  Corre notebooks y tests Python en cada PR hacia main.
# ─────────────────────────────────────────────────────────────

name: 🐍 Qiskit Simulations

on:
  push:
    branches: [main]
    paths:
      - "notebooks/**"
      - "**/*.py"
      - "requirements*.txt"
  pull_request:
    branches: [main]
    paths:
      - "notebooks/**"
      - "**/*.py"
      - "requirements*.txt"

jobs:
  qiskit-simulate:
    name: Qiskit + Jupyter Notebooks
    runs-on: ubuntu-latest

    steps:
      # 1. Checkout
      - name: 📥 Checkout
        uses: actions/checkout@v4

      # 2. Python 3.11
      - name: 🐍 Setup Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      # 3. Instalar dependencias
      - name: 📦 Instalar dependencias
        run: |
          python -m pip install --upgrade pip
          pip install \
            qiskit==1.4.* \
            qiskit-aer==0.15.* \
            qiskit-ibm-runtime \
            jupyter \
            nbconvert \
            nbformat \
            matplotlib \
            numpy \
            scipy

      # 4. Validar sintaxis de archivos Python
      - name: 🔍 Lint Python
        run: |
          pip install ruff
          ruff check . --ignore E501 || true

      # 5. Correr notebook de demo
      - name: 📓 Ejecutar demo_energy.ipynb
        run: |
          jupyter nbconvert \
            --to notebook \
            --execute \
            --ExecutePreprocessor.timeout=120 \
            notebooks/demo_energy.ipynb \
            --output notebooks/demo_energy_executed.ipynb
        continue-on-error: true  # notebook puede no existir todavía

      # 6. Correr tests Python si existen
      - name: 🧪 Tests Python (pytest)
        run: |
          pip install pytest
          pytest tests/ -v --tb=short 2>/dev/null || echo "Sin tests todavía — agrega tests/ para activar."

      # 7. Subir notebook ejecutado como artifact
      - name: 💾 Upload notebook ejecutado
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: notebooks-executed
          path: notebooks/*_executed.ipynb
          retention-days: 14

          # ─────────────────────────────────────────────────────────────
#  QuantumEnergyOS — CI: Validar demo estática (index.html)
#  + Deploy automático a GitHub Pages en push a main.
# ─────────────────────────────────────────────────────────────

name: 🌐 Demo Web + Deploy

on:
  push:
    branches: [main]
    paths:
      - "index.html"
      - "api-simulada.js"
      - "Wallpaper Web"
  pull_request:
    branches: [main]
    paths:
      - "index.html"
      - "api-simulada.js"

# Permisos para GitHub Pages
permissions:
  contents: read
  pages: write
  id-token: write

# Solo un deploy a la vez
concurrency:
  group: "pages"
  cancel-in-progress: false

jobs:
  validate:
    name: 🔍 Validar HTML + JS
    runs-on: ubuntu-latest

    steps:
      - name: 📥 Checkout
        uses: actions/checkout@v4

      - name: ⚙️ Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: 🔍 Validar HTML
        run: |
          npx html-validate index.html || echo "Advertencias de HTML detectadas"

      - name: 🔍 Validar JavaScript
        run: |
          npx eslint api-simulada.js --env browser --no-eslintrc \
            -c '{"rules":{"no-undef":"warn","no-unused-vars":"warn"}}' \
            || echo "Advertencias de JS detectadas"

  deploy-pages:
    name: 🚀 Deploy a GitHub Pages
    runs-on: ubuntu-latest
    needs: validate
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'

    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}

    steps:
      - name: 📥 Checkout
        uses: actions/checkout@v4

      - name: ⚙️ Configurar Pages
        uses: actions/configure-pages@v5

      - name: 📤 Upload artifact de Pages
        uses: actions/upload-pages-artifact@v3
        with:
          path: "."  # raíz del repo (donde está index.html)

      - name: 🚀 Deploy a GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4

        # requirements.txt — QuantumEnergyOS Python dependencies
qiskit==1.4.*
qiskit-aer==0.15.*
qiskit-ibm-runtime
jupyter
nbconvert
nbformat
matplotlib
numpy
scipy
pytest
ruff

# 1. Generar clave GPG
gpg --gen-key

# 2. Obtener el ID
gpg --list-secret-keys --keyid-format=long

# 3. Configurar git globalmente
git config --global user.signingkey TU_KEY_ID
git config --global commit.gpgsign true

# 4. Firmar releases
git tag -s v1.0 -m "Release v1.0 — QuantumEnergyOS"
