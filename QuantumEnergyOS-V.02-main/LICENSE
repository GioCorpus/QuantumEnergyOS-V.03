const iwataCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'KeyB', 'KeyA'];
let iwataIndex = 0;

document.addEventListener('keydown', (e) => {
  if (e.key === iwataCode ) {
    iwataIndex++;
    if (iwataIndex === iwataCode.length) {
      iwataIndex = 0;
      
      // Mensaje Iwata
      const message = document.createElement('div');
      message.innerHTML = `
        <p style="font-family: VT323, monospace; font-size: 28px; color: #00ff00; text-shadow: 0 0 10px #00ff00;">
          Gracias, Iwata-san.<br>
          Por enseñarnos que el código no necesita ser grande...<br>
          solo necesita salvar el día.<br>
          – Un humilde dev de Mexicali
        </p>
      `;
      message.style.position = 'absolute';
      message.style.top = '40%';
      message.style.left = '50%';
      message.style.transform = 'translate(-50%, -50%)';
      message.style.background = 'rgba(0,0,0,0.8)';
      message.style.padding = '20px';
      message.style.border = '4px solid #00ff00';
      message.style.borderRadius = '10px';
      message.style.opacity = '0';
      message.style.transition = 'opacity 1s';
      document.body.appendChild(message);
      
      // Sprite de Iwata (busca un pixel art de Iwata o Kirby-Iwata)
      const iwataSprite = document.createElement('img');
      iwataSprite.src = 'https://i.imgur.com/5jK9m4L.png'; // Reemplaza con sprite real (Iwata pixelado)
      iwataSprite.style.position = 'absolute';
      iwataSprite.style.top = '30%';
      iwataSprite.style.left = '50%';
      iwataSprite.style.transform = 'translate(-50%, -50%)';
      iwataSprite.style.width = '120px';
      iwataSprite.style.imageRendering = 'pixelated';
      iwataSprite.style.filter = 'drop-shadow(0 0 15px lime)';
      iwataSprite.style.opacity = '0';
      document.body.appendChild(iwataSprite);
      
      // Aparecer todo
      setTimeout(() => {
        message.style.opacity = '1';
        iwataSprite.style.opacity = '1';
      }, 100);
      
      // Desvanecer después de 6 segundos
      setTimeout(() => {
        message.style.opacity = '0';
        iwataSprite.style.opacity = '0';
        setTimeout(() => {
          message.remove();
          iwataSprite.remove();
        }, 1000);
      }, 6000);
    }
  } else {
    iwataIndex = 0;
  }
});
