-- DIVISION DE IDENTIFICACION
SELECT 'PROGRAMA: BALANCEO-DE-CARGA' AS PROGRAM_NAME;

-- DIVISION DE DATOS
CREATE TABLE IF NOT EXISTS LOG_BALANCEO (
    ID_BALANCEO          SERIAL PRIMARY KEY,
    FECHA_EJECUCION      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    TOTAL_NODOS          INTEGER,
    CARGA_TOTAL_MW       DECIMAL(10,2),
    CARGA_PROMEDIO_MW    DECIMAL(8,2),
    NODOS_SOBRECARGADOS  INTEGER,
    EFICIENCIA_PCT       DECIMAL(5,2),
    ESTADO               VARCHAR(20)
);

-- DIVISION DE PROCEDIMIENTO
-- Calculamos el balanceo de la red (PROCEDURE DIVISION)

INSERT INTO LOG_BALANCEO (
    TOTAL_NODOS,
    CARGA_TOTAL_MW,
    CARGA_PROMEDIO_MW,
    NODOS_SOBRECARGADOS,
    EFICIENCIA_PCT,
    ESTADO
)
SELECT 
    COUNT(*) AS TOTAL_NODOS,
    SUM(CARGA_ACTUAL_MW) AS CARGA_TOTAL_MW,
    ROUND(AVG(CARGA_ACTUAL_MW), 2) AS CARGA_PROMEDIO_MW,
    COUNT(CASE WHEN CARGA_ACTUAL_MW > (CAPACIDAD_MW * 0.85) THEN 1 END) AS NODOS_SOBRECARGADOS,
    ROUND((1 - AVG((CARGA_ACTUAL_MW / NULLIF(CAPACIDAD_MW, 0)) - 1)) * 100, 2) AS EFICIENCIA_PCT,
    CASE 
        WHEN AVG(CARGA_ACTUAL_MW / NULLIF(CAPACIDAD_MW, 0)) > 0.90 THEN 'CRITICO'
        WHEN AVG(CARGA_ACTUAL_MW / NULLIF(CAPACIDAD_MW, 0)) > 0.80 THEN 'ADVERTENCIA'
        ELSE 'OPTIMO'
    END AS ESTADO
FROM NODOS_RED;

-- Mostramos el resultado del balanceo (DISPLAY)
SELECT 
    'RESULTADO DE BALANCEO DE CARGA' AS TITULO,
    TOTAL_NODOS,
    CARGA_TOTAL_MW,
    CARGA_PROMEDIO_MW,
    NODOS_SOBRECARGADOS,
    EFICIENCIA_PCT || '%' AS EFICIENCIA,
    ESTADO
FROM LOG_BALANCEO 
ORDER BY ID_BALANCEO DESC 
LIMIT 1;
