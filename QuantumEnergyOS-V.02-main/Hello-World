    MENSAJE              VARCHAR(100) NOT NULL,
    FECHA_EJECUCION      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    AUTOR                VARCHAR(50) DEFAULT 'Giovanny Corpus Bernal',
    SISTEMA              VARCHAR(30) DEFAULT 'QuantumEnergyOS'
);

-- DIVISION DE PROCEDIMIENTO (PROCEDURE DIVISION)
-- Aquí es donde realmente "ejecutamos" el programa

