import requests
import os
from datetime import datetime

def enviar_alerta(temperatura, ciudad="Mexicali"):
    mensaje = f"""🔴 **ALERTA CRÍTICA** 🔴

🌡️ Temperatura en **{ciudad}**: `{temperatura}°C`

⚠️ La red eléctrica está en **riesgo alto**.
🕒 {datetime.now().strftime("%d/%m/%Y %H:%M")}"""

    # === Mejor práctica: usar variables de entorno ===
    TOKEN = os.getenv("TELEGRAM_BOT_TOKEN")
    CHAT_ID = os.getenv("TELEGRAM_CHAT_ID")

    if not TOKEN or not CHAT_ID:
        print("❌ Error: Configura las variables de entorno TELEGRAM_BOT_TOKEN y TELEGRAM_CHAT_ID")
        return False

    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    payload = {
        "chat_id": CHAT_ID,
        "text": mensaje,
        "parse_mode": "Markdown"
    }
    
    try:
        response = requests.post(url, data=payload, timeout=10)
        response.raise_for_status()
        print("✅ Notificación enviada por Telegram")
        return True
    except requests.exceptions.RequestException as e:
        print(f"❌ Error al enviar notificación: {e}")
        return False


# Ejemplo de uso
if __name__ == "__main__":
    enviar_alerta(46)
